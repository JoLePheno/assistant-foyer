# Copie ce fichier en « .env » et remplis les valeurs.
#   cp .env.example .env

# Clé API Mistral — https://console.mistral.ai  → API Keys
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# IP locale du Shelly H&T sur ton WiFi (ex. 192.168.1.50).
# Laisse VIDE tant que le capteur n'est pas installé → l'app affiche une valeur de démo.
SHELLY_IP=
